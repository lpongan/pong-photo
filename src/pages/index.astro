---
import Homepage from "../components/Homepage.astro";
import { getImage } from "astro:assets";

const hero = await getImage({
  src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778034719/DSC08239_sntktm.jpg",
  widths: [800, 1200, 1900, 2500],
  width: 2500,
  height: 1667,
  fit: "inside",
  quality: 85,
  decoding: "async",
});

const heroImage = {
  src: hero.src,
  srcset: hero.srcSet.attribute,
  alt: "Your alt text here",
  url: "/portfolio", // where the hero links to
};
---

<Homepage title="Home" images={JSON.stringify([heroImage])} />