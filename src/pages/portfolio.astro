---
import BaseLayout from "../layouts/BaseLayout.astro";
import PortfolioMasonry from "../components/PortfolioMasonry.astro";
import type { PortfolioImage } from "../components/PortfolioMasonry.astro";

const artists: PortfolioImage[] = [
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1777950985/DSC08327_ktm6kk.jpg", alt: "Violinist" },
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778007478/DSC03813_tnjn8z.jpg", alt: "Therian" },
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778007478/DSC03767_nso3qq.jpg", alt: "Therian" },
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778007477/DSC03101_r6cbff.jpg", alt: "Therian" },
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778089087/DSC08044_v0j8cl.jpg", alt: "Costume" },
];

const athletes: PortfolioImage[] = [
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778034719/DSC08239_sntktm.jpg", alt: "Climber" },
  { src: "https://res.cloudinary.com/dvwl2ci5j/image/upload/v1778092706/DSC09063_dszwvv.jpg", alt: "Highline at fourth moon camp" },
];

const families: PortfolioImage[] = [
  // { src: "https://your-cdn.com/families/photo1.jpg", alt: "Family session" },
];
---

<BaseLayout title="Portfolio">
  <div class="flex flex-col gap-12">
    {
      artists.length > 0 && (
        <section>
          <h2 class="font-overpass-mono uppercase tracking-widest text-sm mb-6">
            Artists
          </h2>
          <PortfolioMasonry images={artists} />
        </section>
      )
    }
    {
      athletes.length > 0 && (
        <section>
          <h2 class="font-overpass-mono uppercase tracking-widest text-sm mb-6">
            Athletes
          </h2>
          <PortfolioMasonry images={athletes} />
        </section>
      )
    }
    {
      families.length > 0 && (
        <section>
          <h2 class="font-overpass-mono uppercase tracking-widest text-sm mb-6">
            Families
          </h2>
          <PortfolioMasonry images={families} />
        </section>
      )
    }
    {
      artists.length === 0 &&
        athletes.length === 0 &&
        families.length === 0 && (
          <p class="font-overpass-mono text-sm opacity-50">
            No images yet.
          </p>
        )
    }

    <div class="pt-8 border-t border-current opacity-100" style="border-opacity: 0.1;">
      <div class="flex flex-col gap-4">
        <button
          id="book-cta"
          class="font-overpass-mono uppercase tracking-widest text-sm border border-current px-6 py-3 self-start hover:opacity-70 transition-all"
          style="border-opacity: 0.3;"
        >
          Book Now →
        </button>
        <div id="book-reveal" class="overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0;">
          <div class="flex flex-col gap-2 pb-2">
            <p class="font-overpass-mono uppercase tracking-widest text-xs opacity-60">Call or text</p>
            <a href="tel:+13039216103" class="text-2xl leading-snug hover:opacity-70 transition-opacity">
              (303) 921-6103
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const btn = document.getElementById("book-cta") as HTMLButtonElement;
    const reveal = document.getElementById("book-reveal") as HTMLDivElement;

    btn.addEventListener("click", () => {
      const isOpen = reveal.style.maxHeight !== "0px" && reveal.style.maxHeight !== "";
      if (isOpen) {
        reveal.style.maxHeight = "0";
        btn.textContent = "Book Now →";
      } else {
        reveal.style.maxHeight = reveal.scrollHeight + "px";
        btn.textContent = "Close ×";
      }
    });
  </script>
</BaseLayout>
