---
import Hamburger from "./Hamburger.tsx";
import Navigation from "./Navigation.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { getImage } from "astro:assets";
import { CDN_FAVICON_URL } from "../consts";

export interface Props {
  is404Page?: boolean;
}

const { is404Page = false } = Astro.props;

const favicon_avif = await getImage({
  src: CDN_FAVICON_URL,
  alt: "favicon",
  height: 100,
  width: 100,  
  decoding: "async",
  format: "avif",
});
---

<header class="mb-[20px] mt-[-10px]">
  <nav aria-label="Main navigation" class="flex items-center justify-between w-full h-[100px]">
    {
      !is404Page && (
        <div class="flex items-center h-[100px] w-[100px]">
          <a href="/" class="block">
            <img
              class="favicon dark h-[100px] w-[100px]"
              src={favicon_avif.src}
              alt="Home"
              height="100"
              width="100"
            />
          </a>
        </div>
      )
    }
    <div class="flex items-center h-[100px] gap-2">
      {
        !is404Page && (
          <>
            <div class="flex items-center justify-center h-[30px] w-[30px]">
              <button id="searchTrigger" class="w-[30px] h-[30px] bg-transparent border-0 p-0 cursor-pointer flex items-center justify-center" aria-label="Search" aria-haspopup="dialog">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
              </button>
            </div>
            <div class="flex items-center justify-center h-[30px] w-[30px]">
              <ThemeToggle />
            </div>
            <div class="flex items-center justify-center h-[30px] w-[30px]">
              <Hamburger client:idle />
            </div>
          </>
        )
      }
    </div>
  </nav>
  {
    !is404Page && (
      <div class="absolute right-0 mt-2">
        <Navigation />
      </div>
    )
  }
  <slot />
</header>
